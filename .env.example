# Environment Type: dev, staging, prod
ENV=dev

# Database Connection String
# Defaults to local SQLite for development. 
# In production, replace with a PostgreSQL URI: postgresql://user:pass@host:port/dbname
DATABASE_URL=sqlite:///./compliance.db

# Cryptographically secure random key for JWT token signatures
# Generate using: openssl rand -hex 32
JWT_SECRET_KEY=dev_secret_key_change_me_in_production

# JWT Token expiration period
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Allowed Origins (comma-separated strings)
CORS_ORIGINS=http://localhost:3000
